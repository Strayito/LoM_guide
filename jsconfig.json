{
  "compilerOptions": {
    "checkJs": true,
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "allowImportingTsExtensions": false
  },
  "include": ["assets/js/**/*.js", "data/**/*.html"]
}
